# --- SEGURIDAD ---
wp-config.php
.htaccess
*.log
/wp-content/backups/
/wp-content/upgrade/

# --- ARCHIVOS DE SISTEMA Y CACHÉ ---
.DS_Store
Thumbs.db
wp-content/cache/
wp-content/et-cache/
node_modules/

# --- CONTENIDO MULTIMEDIA (No se sube a Git) ---
# Las imágenes deben ir por copia de seguridad aparte, no en el repo
/wp-content/uploads/

# --- CORE (Opcional) ---
# Si quieres que el repo sea ligero y los técnicos instalen WP aparte, déjalo así.
# Si quieres que al clonar ya esté WP ahí, comenta estas líneas con un #
/wp-admin/
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php
!/wp-content/

# --- TEMAS Y PLUGINS ---
# Subiremos todo el contenido de temas y plugins para que el técnico 
# tenga el sitio funcional al clonar.
# (Ignoramos solo los temas por defecto de WP para no ensuciar)
/wp-content/themes/twenty*/

# --- CONFIGURACIÓN PARA TÉCNICOS ---
