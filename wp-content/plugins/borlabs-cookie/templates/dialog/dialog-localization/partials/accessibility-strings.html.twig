{% embed "system/embed/card/card-with-title.html.twig" with { contentSpacing: false, hideInSimplifiedMode: true } %}
    {% import "system/macro/row/input.html.twig" as row_input %}
    {% import "system/macro/row/textarea.html.twig" as row_textarea %}
    {% import "system/macro/row/save.html.twig" as row_save %}
    {% import "system/macro/card/card-heading.html.twig" as card_heading %}
    {% block header %}
        {{ card_heading.component({
            title: localized.headline.a11y,
        }) }}
    {% endblock %}
    {% block content %}
        {{ row_input.component({
            id: 'a11yDialogCloseButton',
            label: localized.field.a11yDialogCloseButton,
            value: data.a11yDialogCloseButton,
        }) }}

        {{ row_textarea.component({
            id: 'a11yDialogCloseButtonExplained',
            label: localized.field.a11yDialogCloseButtonExplained,
            value: data.a11yDialogCloseButtonExplained,
        }) }}

        {{ row_input.component({
            id: 'a11yWidgetButton',
            label: localized.field.a11yWidgetButton,
            value: data.a11yWidgetButton,
        }) }}

        {{ row_textarea.component({
            id: 'a11yProviderDialogExplained',
            label: localized.field.a11yProviderDialogExplained,
            value: data.a11yProviderDialogExplained,
        }) }}

        {{ row_textarea.component({
            id: 'a11yProviderListExplained',
            label: localized.field.a11yProviderListExplained,
            value: data.a11yProviderListExplained,
        }) }}

        {{ row_textarea.component({
            id: 'a11yServiceGroupListExplained',
            label: localized.field.a11yServiceGroupListExplained,
            value: data.a11yServiceGroupListExplained,
        }) }}

        {{ row_input.component({
            id: 'a11yRegionServices',
            label: localized.field.a11yRegionServices,
            value: data.a11yRegionServices,
        }) }}

        {{ row_textarea.component({
            id: 'a11yRegionServicesExplained',
            label: localized.field.a11yRegionServicesExplained,
            value: data.a11yRegionServicesExplained,
        }) }}

        {{ row_save.component({
            action: 'save',
            nonce: wpNonceField("#{controllerId}-save"),
        }, localized) }}
    {% endblock %}
{% endembed %}
