{% embed "system/embed/card/card-with-title.html.twig" with { contentSpacing: false, hideInSimplifiedMode: true } %}
    {% import "system/macro/row/input.html.twig" as row_input %}
    {% import "system/macro/row/textarea.html.twig" as row_textarea %}
    {% import "system/macro/row/save.html.twig" as row_save %}
    {% import "system/macro/card/card-heading.html.twig" as card_heading %}
    {% block header %}
        {{ card_heading.component({
            title: localized.headline.dialogIabTcfA11y,
        }) }}
    {% endblock %}
    {% block content %}
        {{ row_textarea.component({
            id: 'iabTcfA11yPurposeListExplained',
            label: localized.field.iabTcfA11yPurposeListExplained,
            value: data.iabTcfA11yPurposeListExplained,
        }) }}

        {{ row_textarea.component({
            id: 'iabTcfA11yServiceGroupListExplained',
            label: localized.field.iabTcfA11yServiceGroupListExplained,
            value: data.iabTcfA11yServiceGroupListExplained,
        }) }}

        {{ row_input.component({
            id: 'iabTcfA11yRegionTcfVendorConsentHistory',
            label: localized.field.iabTcfA11yRegionTcfVendorConsentHistory,
            value: data.iabTcfA11yRegionTcfVendorConsentHistory,
        }) }}

        {{ row_textarea.component({
            id: 'iabTcfA11yRegionTcfVendorConsentHistoryExplained',
            label: localized.field.iabTcfA11yRegionTcfVendorConsentHistoryExplained,
            value: data.iabTcfA11yRegionTcfVendorConsentHistoryExplained,
        }) }}

        {{ row_input.component({
            id: 'iabTcfA11yRegionVendors',
            label: localized.field.iabTcfA11yRegionVendors,
            value: data.iabTcfA11yRegionVendors,
        }) }}

        {{ row_textarea.component({
            id: 'iabTcfA11yRegionVendorsExplained',
            label: localized.field.iabTcfA11yRegionVendorsExplained,
            value: data.iabTcfA11yRegionVendorsExplained,
        }) }}

        {{ row_save.component({}, localized) }}
    {% endblock %}
{% endembed %}
