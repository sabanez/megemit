{% if data.licenseKey is not empty %}
    {% embed "system/embed/card/card-with-info-panel.html.twig" %}
        {% import "system/macro/card/card-heading.html.twig" as card_heading %}

        {% block mainHeader %}
            {{ card_heading.component({
                title: localized.headline.removeLicense,
            }) }}
        {% endblock %}

        {% block mainContent %}
            {% import "system/macro/form/confirmation-without-card.html.twig" as form_confirmation_without_card %}

            {{ form_confirmation_without_card.component({
                action: 'remove',
                button: localized.button.removeLicense,
                hint: localized.hint.removeLicense,
                nonce: wpNonceField("#{controllerId}-remove"),
                route: "?page=#{controllerId}",
                title: localized.field.confirmRemovingLicense,
            }, localized) }}
        {% endblock %}

        {% block infoPanelHeader %}
            {{ localized.global.headline.thingsToKnow | raw }}
        {% endblock %}

        {% block infoPanelContent %}
            {% embed "system/embed/accordion/accordion-group.html.twig" %}
                {% block content %}
                    {% embed "system/embed/accordion/accordion.html.twig" with {id: 'accordionTransferringLicenseKeyToNewWebsite', expanded: false} %}
                        {% block title %}
                            {{ localized.thingsToKnow.headlineTransferringLicenseKeyToNewWebsite | raw }}
                        {% endblock %}

                        {% block content %}
                            <p>{{ localized.thingsToKnow.transferringLicenseKeyToNewWebsiteA | raw }}</p>
                            <p class="bc-text-center">{{ localized.thingsToKnow.customerPortal | raw }}</p>
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
{% endif %}
