{% import "setup-assistant/macro/direction-buttons.html.twig" as direction_buttons %}

<div class="bc-hidden" data-brlbs-setup-flow="dialog-logo">
    {% embed "system/embed/card/card-with-info-panel-below.html.twig" with { withHeaderBorder: true } %}
        {% import "system/macro/card/card-heading-with-subtitle.html.twig" as card_heading_with_subtitle %}
        {% import "system/macro/form-component/media-selection.html.twig" as media_selection %}
        {% import "system/macro/form-component/switch-button.html.twig" as switch_button %}

        {% block mainHeader %}
            {{ card_heading_with_subtitle.component({
                title: localized.headline.logo,
                subtitle: localized.headline.dialogSettings,
            }) }}
        {% endblock %}

        {% block mainContent %}
            <fieldset class="bc-p-6">
                <legend class="bc-pt-6 bc-text-lg bc-font-medium bc-text-center">{{ localized.headline.selectDialogLogo | raw }}</legend>
                <div class="bc-flex bc-flex-col bc-gap-y-4">
                    <div class="bc-flex bc-gap-x-4 bc-self-center bc-items-center">
                        <label for="showLogo">{{ localized.field.showLogo | raw }}</label>
                        {{ switch_button.component({
                            dataAttribute: 'data-brlbs-blurer="mediaSelectionField" data-brlbs-enable-target="showLogo"',
                            id: 'showLogo',
                            value: true,
                        }) }}
                    </div>
                    <div id="mediaSelectionField" class="bc-w-full sm:bc-w-1/3 bc-self-center brlbs-cmpnt-blurable">
                        {{ media_selection.component({
                            button: localized.button.useThisMedia,
                            centerPreview: true,
                            id: 'logo',
                            label: localized.field.logo,
                            title: localized.button.selectOrUploadLogo,
                            value: data.logo
                        }, localized) }}
                    </div>
                </div>
            </fieldset>
        {% endblock %}

        {% block infoPanelHeader %}
            {{ localized.global.headline.thingsToKnow | raw }}
        {% endblock %}

        {% block infoPanelContent %}
            {% embed "system/embed/accordion/accordion-group.html.twig" %}
                {% block content %}
                    {% embed "system/embed/accordion/accordion.html.twig" with {id: 'accordionLogo', expanded: true } %}
                        {% block title %}
                            {{ localized.thingsToKnow.headlineLogoSize | raw }}
                        {% endblock %}
                        {% block content %}
                            <p>{{ localized.thingsToKnow.logoSize | raw }}</p>
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}

    {{ direction_buttons.component({
        currentStep: 3 + (data.setupType == 'guided' ? 5 : 0),
        steps: data.setupSteps,
    }, localized) }}
</div>
