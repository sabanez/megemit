<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="color-scheme" content="light">
    <meta name="supported-color-schemes" content="light">
    <style>
@media only screen and (max-width: 600px) {
  .brlbs-cmpnt-inner-body {
    width: 100% !important;
  }
  .brlbs-cmpnt-footer {
    width: 100% !important;
  }
  .brlbs-cmpnt-inner-body {
    width: 100% !important;
  }
  .brlbs-cmpnt-footer {
    width: 100% !important;
  }
}</style>
</head>
<body style="-webkit-text-size-adjust: none; background-color: #ffffff; color: #718096; height: 100%; line-height: 1.4; margin: 0; padding: 0; width: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif,
        'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol';">
<div>
    <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse: collapse; border-spacing: 0; -premailer-cellpadding: 0; -premailer-cellspacing: 0; -premailer-width: 100%; background-color: #edf2f7; margin: 0; padding: 0; width: 100%;">
        <tr>
            <td align="center">
                <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse: collapse; border-spacing: 0; -premailer-cellpadding: 0; -premailer-cellspacing: 0; -premailer-width: 100%; margin: 0; padding: 0; width: 100%;">
                    <tr>
                        <td style="margin: 100%; width: 16px; padding: 25px 0; text-align: center;">
                            <a href="https://borlabs.io/" style="display: inline-block; color: #3d4852; font-size: 19px; font-weight: bold; text-decoration: none;">
                                <img src="{{ imageUrl('borlabs-cookie-dark-mobile.png') }}" alt style="max-width: 100%; vertical-align: middle; min-height: 97px; width: 192px;" width="192">
                            </a>
                        </td>
                    </tr>
                    <tr>
                        <td class="brlbs-cmpnt-outer-body" width="100%" cellpadding="0" cellspacing="0" style="-premailer-cellpadding: 0; -premailer-cellspacing: 0; -premailer-width: 100%; background-color: #edf2f7; border-bottom: 1px solid #edf2f7; border-top: 1px solid #edf2f7; margin: 0; padding: 0; width: 100%;">
                            <table class="brlbs-cmpnt-inner-body" align="center" width="570" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse: collapse; border-spacing: 0; -premailer-cellpadding: 0; -premailer-cellspacing: 0; -premailer-width: 570px; background-color: #ffffff; border-color: #e8e5ef; border-radius: 8px; border-width: 1px; box-shadow: 0 0 #0000, 0 0 #0000, 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); margin: 0 auto; padding: 0; width: 570px"> <tr>
                                    <td style="max-width: 100vw; padding: 32px; background-color: #ffffff;">    <p>{{ localized.shared.text.mailInformation | raw }}</p>
    {% if data.plannedPackageUpdates %}
        <p>{{ localized.text.automaticUpdatePlannedForFollowingPackages | raw  }}</p>
        {% for plannedPackageUpdate in data.plannedPackageUpdates %}
            <table style="border-collapse: collapse; border-spacing: 0; width: 100%;" cellpadding="0" cellspacing="0" role="none">
                <tr style="background-color: #f9fafb;">
                    <th style="padding: 12px; text-align: left;">{{ localized.table.package }}</th>
                    <td style="padding: 12px;">{{ plannedPackageUpdate.package.name | raw }}</td>
                </tr>
                <tr>
                    <th style="padding: 12px; text-align: left;">{{ localized.table.overwriteCode | raw  }}</th>
                    <td style="padding: 12px;">
                        {% if plannedPackageUpdate.package.autoUpdateOverwriteCode %}
                            <img style="max-width: 100%; vertical-align: middle; display: block; height: 20px; width: 20px;" src="{{ imageUrl('icon-check-circle.png') }}" alt width="20" height="20">
                        {% else %}
                            <img style="max-width: 100%; vertical-align: middle; display: block; height: 20px; width: 20px;" src="{{ imageUrl('icon-x-circle.png') }}" alt width="20" height="20">
                        {% endif %}
                    </td>
                </tr>
                <tr style="background-color: #f9fafb;">
                    <th style="padding: 12px; text-align: left;">{{ localized.table.overwriteTranslation | raw  }}</th>
                    <td style="padding: 12px;">
                        {% if plannedPackageUpdate.package.autoUpdateOverwriteTranslation %}
                            <img style="max-width: 100%; vertical-align: middle; display: block; height: 20px; width: 20px;" src="{{ imageUrl('icon-check-circle.png') }}" alt width="20" height="20">
                        {% else %}
                            <img style="max-width: 100%; vertical-align: middle; display: block; height: 20px; width: 20px;" src="{{ imageUrl('icon-x-circle.png') }}" alt width="20" height="20">
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th style="padding: 12px; text-align: left;">{{ localized.table.installedVersion | raw  }}</th>
                    <td style="padding: 12px;">{{ versionNumber(plannedPackageUpdate.package.version) | raw }}</td>
                </tr>
                <tr style="background-color: #f9fafb;">
                    <th style="padding: 12px; text-align: left;">{{ localized.table.latestVersion | raw  }}</th>
                    <td style="padding: 12px;">{{ versionNumber(plannedPackageUpdate.package.borlabsServicePackageVersion) | raw }}</td>
                </tr>
                <tr>
                    <th style="padding: 12px; text-align: left;">{{ localized.table.plannedFor | raw  }}</th>
                    <td style="padding: 12px;">{{ plannedPackageUpdate.plannedFor.format('Y-m-d H:i') }}  UTC+00:00</td>
                </tr>
            </table>
            <div style="margin-top: 16px; margin-bottom: 16px; border: solid #e5e7eb; border-width: 0px 0px 1px;"></div>
        {% endfor %}
    {% endif %}
    {% if data.updatablePackagesWithAutoUpdateDisabled %}
        <p>{{ localized.text.updatablePackagesWithAutoUpdateDisabled | raw  }}</p>
        <table style="border-collapse: collapse; border-spacing: 0; width: 100%;" cellpadding="0" cellspacing="0" role="none">
            <tr style="background-color: #f9fafb;">
                <th style="padding: 12px; text-align: left;">{{ localized.table.package }}</th>
                <th style="padding: 12px; text-align: left;">{{ localized.table.installedVersion | raw  }}</th>
                <th style="padding: 12px; text-align: left;">{{ localized.table.latestVersion | raw  }}</th>
            </tr>
        {% for updatablePackageWithAutoUpdateDisabled in data.updatablePackagesWithAutoUpdateDisabled %}
            {% set trClassName = loop.index is divisible by (2) ? '#f9fafb' : '#fff' %}
            <tr style="background-color: {{ trClassName }};">
                <td style="padding: 12px;">{{ updatablePackageWithAutoUpdateDisabled.name | raw }}</td>
                <td style="padding: 12px;">{{ versionNumber(updatablePackageWithAutoUpdateDisabled.version) | raw }}</td>
                <td style="padding: 12px;">{{ versionNumber(updatablePackageWithAutoUpdateDisabled.borlabsServicePackageVersion) | raw }}</td>
            </tr>
        {% endfor %}
        </table>
        <div style="margin-top: 16px; margin-bottom: 16px; border: solid #e5e7eb; border-width: 0px 0px 1px;"></div>
    {% endif %}
    <p>{{ localized.shared.text.removeFromMailingList | raw }}</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <table class="brlbs-cmpnt-footer" align="center" width="570" cellpadding="0" cellspacing="0" role="presentation" style="border-collapse: collapse; border-spacing: 0; -premailer-cellpadding: 0; -premailer-cellspacing: 0; -premailer-width: 570px; margin: 0 auto; padding: 0; text-align: center; width: 570px">
                                <tr>
                                    <td align="center" style="max-width: 100vw; padding: 32px;">
                                        <p style="color: #b0adc5; font-size: 12px; text-align: center;">Borlabs Cookie&reg; - <a href="https://borlabs.io/" style="color: #b0adc5; text-decoration: underline;">Borlabs GmbH</a></p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</div>
</body>
</html>
